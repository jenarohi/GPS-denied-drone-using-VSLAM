# ============================================================================
# VSLAM-UAV Runtime Configuration
# Modify these values to match your hardware setup
# ============================================================================

# ── Pixhawk Connection ──────────────────────────────────────────────────────
PIXHAWK_PORT=/dev/ttyUSB0
PIXHAWK_BAUD=921600

# ── ROS 2 Network ──────────────────────────────────────────────────────────
ROS_DOMAIN_ID=1
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# ── RealSense Camera Settings ──────────────────────────────────────────────
RS_RESOLUTION=640x360
RS_FRAMERATE=90
RS_IMU_RATE=200

# ── Container Settings ─────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=vslam-uav
